    {
      "id": "Ve2JFiPLTXi5Aum2FBhBQ",
      "type": "text",
      "x": 360424.1398283864,
      "y": -3989.4914177619985,
      "width": 492.7998046875,
      "height": 490,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bC2",
      "roundness": null,
      "seed": 549640764,
      "version": 243,
      "versionNonce": 1227184388,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777567552341,
      "link": null,
      "locked": false,
      "text": "// find sum of digits of input\n\nint f(int N)\n{\n\n    if N == 0:\n        return 0\n\n    int smallAns = f(N / 10);\n    \n    int ans = smallAns + N % 10;\n\n    return ans;\n}",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// find sum of digits of input\n\nint f(int N)\n{\n\n    if N == 0:\n        return 0\n\n    int smallAns = f(N / 10);\n    \n    int ans = smallAns + N % 10;\n\n    return ans;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
