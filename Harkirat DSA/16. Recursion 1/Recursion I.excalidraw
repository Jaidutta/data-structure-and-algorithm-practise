      "isDeleted": false,
      "boundElements": [],
      "updated": 1777567327888,
      "link": null,
      "locked": false,
      "text": "\nint f(int A, int B)\n{\n    if B == 0:\n        return 1\n\n    int smallAns = f(A, B - 1);\n\n    int ans = A * smallAns;\n\n    return ans;\n}",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nint f(int A, int B)\n{\n    if B == 0:\n        return 1\n\n    int smallAns = f(A, B - 1);\n\n    int ans = A * smallAns;\n\n    return ans;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
