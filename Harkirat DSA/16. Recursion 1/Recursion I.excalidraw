      "text": "f(N)\n    if N == 0:\n        return     \n\n    print(N % 10)\n    f(N / 10)\n\nmain()\n\n    n = input()\n\n    if n == 0:\n        print(0)\n    else:\n        f(n)",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "f(N)\n    if N == 0:\n        return     \n\n    print(N % 10)\n    f(N / 10)\n\nmain()\n\n    n = input()\n\n    if n == 0:\n        print(0)\n    else:\n        f(n)",
      "autoResize": true,
      "lineHeight": 1.25
    },
