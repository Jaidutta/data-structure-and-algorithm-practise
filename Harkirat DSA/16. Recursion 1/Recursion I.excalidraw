    {
      "id": "3lsyhitmtqtl4teRbNDM7",
      "type": "text",
      "x": 362694.11950581986,
      "y": -3626.9401791468267,
      "width": 554.3997802734375,
      "height": 560,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCd",
      "roundness": null,
      "seed": 1838799620,
      "version": 287,
      "versionNonce": 1729598340,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777567899644,
      "link": null,
      "locked": false,
      "text": "// Nth Fibo term\n\nint f(int N)\n{\n    if N == 1:\n     return 0\n\n    if N == 2:\n        return 1     \n      \n    int smallAns1 = f(N - 1);\n    int smallAns2 = f(N - 2);\n\n    int ans = smallAns1 + smallAns2;\n    return ans;\n}",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// Nth Fibo term\n\nint f(int N)\n{\n    if N == 1:\n     return 0\n\n    if N == 2:\n        return 1     \n      \n    int smallAns1 = f(N - 1);\n    int smallAns2 = f(N - 2);\n\n    int ans = smallAns1 + smallAns2;\n    return ans;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
