    {
      "id": "najapzfUN-rImQrW61WLk",
      "type": "text",
      "x": 356756.5207487656,
      "y": -4246.279879420521,
      "width": 569.7998046875,
      "height": 385,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bAU",
      "roundness": null,
      "seed": 1656638140,
      "version": 154,
      "versionNonce": 760928316,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777567030888,
      "link": null,
      "locked": false,
      "text": "int f(int N)\n{\n    if N == 1:\n        return 1\n        \n    int smallAns = f(N - 1); // Faith\n    \n    int ans = smallAns + N;\n\n    return ans;\n}",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "int f(int N)\n{\n    if N == 1:\n        return 1\n        \n    int smallAns = f(N - 1); // Faith\n    \n    int ans = smallAns + N;\n\n    return ans;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
